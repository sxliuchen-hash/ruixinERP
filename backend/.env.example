# 服务配置
PORT=3001
NODE_ENV=development

# ERP 数据库
DB_HOST=localhost
DB_PORT=3306
DB_NAME=erp_db
DB_USER=root
DB_PASSWORD=your_password_here

# 主项目数据库（只读）
MAIN_DB_HOST=localhost
MAIN_DB_PORT=3306
MAIN_DB_NAME=patent_notice_system
MAIN_DB_USER=root
MAIN_DB_PASSWORD=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 日志
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173

# 企业微信
# CorpID：企业信息页底部，已确认
WECHAT_CORP_ID=wwed291a8364287ea4
# AgentID：审批应用详情页底部
WECHAT_AGENT_ID=
# Secret：审批应用详情页查看（43 位）
WECHAT_SECRET=
# 回调 Token：自定义字符串（部署后在企微后台配置回调时设置）
WECHAT_TOKEN=
# EncodingAESKey：43 位，企微后台随机生成
WECHAT_AES_KEY=

# 企业微信审批模板映射（T10 使用，按需填入）
# 合同审批模板 ID
WECHAT_TEMPLATE_CONTRACT=
# 报销模板 ID
WECHAT_TEMPLATE_EXPENSE=
# 借款模板 ID
WECHAT_TEMPLATE_LOAN=
# 付款申请模板 ID
WECHAT_TEMPLATE_PAYMENT=

# IP 系统（知识产权官文管理系统）
IP_API_BASE_URL=https://iptt.top/api/v1

# 腾讯云 COS
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=your_bucket
COS_REGION=ap-guangzhou
